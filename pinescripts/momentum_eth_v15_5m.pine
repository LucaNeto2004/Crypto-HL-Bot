//@version=6
// v15-5M: v14 + regime filter (skip choppy + weak trend + extreme vol)
// Optimised for 5M timeframe based on OOS validation
// Regime filter: Skip choppy markets + require trend slope > 0.1 + cap extreme vol
strategy("Momentum Ethereum v15-5M (Pyr=3, Qty=20%) [WH]", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=20, pyramiding=3)

// ── Inputs ──────────────────────────────────────────────────
secretKey    = input.string("CHANGE_ME", "Webhook Secret", tooltip="Shared secret for webhook auth")
rsiLMin      = input.int(50,   "RSI Long Min")
rsiLMax      = input.int(80,   "RSI Long Max")
rsiSMax      = input.int(50,   "RSI Short Max")
rsiSMin      = input.int(20,   "RSI Short Min")
atrSM        = input.float(0.7, "ATR Stop Mult")
trailATR     = input.float(0.3, "Trail ATR Mult")
volMin       = input.float(0.0, "Min Volume Ratio")
srRsiLong    = input.int(40,   "Signal Rev RSI Long Thresh")
srRsiShort   = input.int(60,   "Signal Rev RSI Short Thresh")

// Regime filter inputs
useRegime    = input.bool(true, "Enable Regime Filter", tooltip="Skip entries in unfavourable conditions")
slopePeriod  = input.int(20,   "EMA50 Slope Lookback")
minSlope     = input.float(0.1, "Min Trend Slope", tooltip="Minimum absolute EMA50 slope")
choppyMult   = input.float(0.8, "Choppy ATR Mult", tooltip="Skip when ATR < this * ATR_MA")
maxAtrRatio  = input.float(2.0, "Max ATR Ratio", tooltip="Skip when ATR/ATR_MA exceeds this")

// ── Indicators ──────────────────────────────────────────────
ema9  = ta.ema(close, 9)
ema21 = ta.ema(close, 21)
ema50 = ta.ema(close, 50)
rsi   = ta.rsi(close, 14)
atr   = ta.atr(14)

[ml, sl2, mh] = ta.macd(close, 12, 26, 9)

volAvg = ta.sma(volume, 20)
volR   = volume / volAvg
atrMA  = ta.sma(atr, 20)

// ── Regime Filter: Combined ─────────────────────────────────
ema50Slope    = math.abs((ema50 - ema50[slopePeriod]) / ema50[slopePeriod] * 100)
atrRatio      = atr / atrMA
isChoppy      = atr < atrMA * choppyMult
isWeakTrend   = ema50Slope[1] < minSlope
isExtremeVol  = atrRatio > maxAtrRatio

regimeOK = not useRegime or (not isChoppy[1] and not isWeakTrend and not isExtremeVol[1])

// ── Entry Conditions (shifted [1] = no look-ahead bias) ─────
goLong  = close[1] > ema9[1] and ema9[1] > ema21[1] and close[1] > ema50[1] and rsi[1] > rsiLMin and rsi[1] < rsiLMax and mh[1] > 0 and volR[1] >= volMin and regimeOK
goShort = close[1] < ema9[1] and ema9[1] < ema21[1] and close[1] < ema50[1] and rsi[1] < rsiSMax and rsi[1] > rsiSMin and mh[1] < 0 and volR[1] >= volMin and regimeOK

// ── Signal Reversal Conditions (shifted [1]) ────────────────
sigRevCloseLong  = rsi[1] < srRsiLong  and mh[1] < 0
sigRevCloseShort = rsi[1] > srRsiShort and mh[1] > 0

// ── Pyramid Layer ID ────────────────────────────────────────
openCount = strategy.opentrades

// ── Entries ─────────────────────────────────────────────────
if goLong
    pid = "L" + str.tostring(openCount + 1)
    strategy.entry(pid, strategy.long, alert_message='{"secret":"' + secretKey + '","strategy":"momentum","symbol":"ETH","action":"entry_long","position_id":"' + pid + '","price":' + str.tostring(close) + ',"stop_loss":' + str.tostring(close[1] - atr[1] * atrSM) + ',"trail_offset":' + str.tostring(atr[1] * trailATR) + '}')
    strategy.exit(pid + "T", pid, stop=close[1] - atr[1] * atrSM, trail_points=atr[1] * trailATR / syminfo.mintick, trail_offset=atr[1] * trailATR / syminfo.mintick, alert_message='{"secret":"' + secretKey + '","strategy":"momentum","symbol":"ETH","action":"exit_long","position_id":"' + pid + '","price":' + str.tostring(close) + '}')

if goShort
    pid = "S" + str.tostring(openCount + 1)
    strategy.entry(pid, strategy.short, alert_message='{"secret":"' + secretKey + '","strategy":"momentum","symbol":"ETH","action":"entry_short","position_id":"' + pid + '","price":' + str.tostring(close) + ',"stop_loss":' + str.tostring(close[1] + atr[1] * atrSM) + ',"trail_offset":' + str.tostring(atr[1] * trailATR) + '}')
    strategy.exit(pid + "T", pid, stop=close[1] + atr[1] * atrSM, trail_points=atr[1] * trailATR / syminfo.mintick, trail_offset=atr[1] * trailATR / syminfo.mintick, alert_message='{"secret":"' + secretKey + '","strategy":"momentum","symbol":"ETH","action":"exit_short","position_id":"' + pid + '","price":' + str.tostring(close) + '}')

// ── Signal Reversal Closes ──────────────────────────────────
if strategy.position_size > 0 and sigRevCloseLong
    strategy.close_all(comment="Sig Rev", alert_message='{"secret":"' + secretKey + '","strategy":"momentum","symbol":"ETH","action":"close_all","price":' + str.tostring(close) + ',"reason":"signal_reversal"}')

if strategy.position_size < 0 and sigRevCloseShort
    strategy.close_all(comment="Sig Rev", alert_message='{"secret":"' + secretKey + '","strategy":"momentum","symbol":"ETH","action":"close_all","price":' + str.tostring(close) + ',"reason":"signal_reversal"}')

// ── Plots ───────────────────────────────────────────────────
plot(ema9,  "EMA 9",  color.blue)
plot(ema21, "EMA 21", color.orange)
plot(ema50, "EMA 50", color.gray, linewidth=2)

regimeBlocked = useRegime and not regimeOK
bgcolor(isChoppy[1] and regimeBlocked ? color.new(color.orange, 90) : na, title="Choppy Zone")
bgcolor(isWeakTrend and regimeBlocked ? color.new(color.red, 90) : na, title="Weak Trend Zone")
bgcolor(isExtremeVol[1] and regimeBlocked ? color.new(color.purple, 90) : na, title="Extreme Vol Zone")

plotshape(goLong,  "Long",  shape.triangleup,   location.belowbar, color.green, size=size.small)
plotshape(goShort, "Short", shape.triangledown,  location.abovebar, color.red,   size=size.small)

var table regimeTable = table.new(position.top_right, 2, 5, bgcolor=color.new(color.black, 80))
if barstate.islast
    table.cell(regimeTable, 0, 0, "Trend Slope", text_color=color.white, text_size=size.small)
    table.cell(regimeTable, 1, 0, str.tostring(ema50Slope, "#.##") + "%", text_color=not isWeakTrend ? color.green : color.red, text_size=size.small)
    table.cell(regimeTable, 0, 1, "ATR Ratio", text_color=color.white, text_size=size.small)
    table.cell(regimeTable, 1, 1, str.tostring(atrRatio, "#.##"), text_color=not isExtremeVol and not isChoppy ? color.green : color.red, text_size=size.small)
    table.cell(regimeTable, 0, 2, "Choppy", text_color=color.white, text_size=size.small)
    table.cell(regimeTable, 1, 2, isChoppy ? "YES" : "NO", text_color=not isChoppy ? color.green : color.orange, text_size=size.small)
    table.cell(regimeTable, 0, 3, "Regime", text_color=color.white, text_size=size.small)
    table.cell(regimeTable, 1, 3, regimeOK ? "ACTIVE" : "PAUSED", text_color=regimeOK ? color.green : color.red, text_size=size.small)
    table.cell(regimeTable, 0, 4, "Filters", text_color=color.white, text_size=size.small)
    table.cell(regimeTable, 1, 4, "Chop+Trend+Vol", text_color=color.white, text_size=size.small)
